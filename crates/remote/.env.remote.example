# Copy to crates/remote/.env.remote for a local-first setup.

SERVER_DATABASE_URL=postgres://remote:remote@localhost:5432/remote
SERVER_LISTEN_ADDR=127.0.0.1:4000
SERVER_PUBLIC_BASE_URL=http://localhost:4000
ELECTRIC_ROLE_PASSWORD=remote
SELF_HOST_LOCAL_AUTH_EMAIL=admin@local
RUST_LOG=info,remote=info
VIBEKANBAN_REMOTE_JWT_SECRET=replace_with_a_long_random_secret
SELF_HOST_LOCAL_AUTH_PASSWORD=replace_with_a_local_password

# Optional: keep the old Electric stub behavior
# ELECTRIC_URL=http://localhost:1

# Optional OAuth providers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional relay / desktop integration
VITE_RELAY_API_BASE_URL=http://localhost:8082
VK_SHARED_API_BASE=http://localhost:4000

# Optional services
LOOPS_EMAIL_API_KEY=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REVIEW_ENDPOINT=
R2_REVIEW_BUCKET=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=
