# Local-first self-host example for crates/remote
# Copy to crates/remote/.env.remote and fill in real values as needed.

# Required
SERVER_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/vibe_kanban
SERVER_LISTEN_ADDR=0.0.0.0:4000
SERVER_PUBLIC_BASE_URL=http://localhost:4000
VIBEKANBAN_REMOTE_JWT_SECRET=replace_with_a_long_random_secret

# Local auth bootstrap (use this or configure GitHub/Google OAuth below)
SELF_HOST_LOCAL_AUTH_EMAIL=admin@example.com
SELF_HOST_LOCAL_AUTH_PASSWORD=change-me

# Optional OAuth providers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional Electric settings
# Leave unset to disable Electric proxy routes in local-only mode.
ELECTRIC_URL=
ELECTRIC_SECRET=
ELECTRIC_ROLE_PASSWORD=
ELECTRIC_PUBLICATION_NAMES=

# Optional relay / desktop integration
VITE_RELAY_API_BASE_URL=http://localhost:8082
VK_SHARED_API_BASE=http://localhost:4000

# Optional services
LOOPS_EMAIL_API_KEY=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REVIEW_ENDPOINT=
R2_REVIEW_BUCKET=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=
